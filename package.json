{
  "name": "vectraguard",
  "version": "1.0.0",
  "description": "VectraGuard-Cross-Platform Application",
  "private": true,
  "main": "index.js",
  "workspaces": [
    "BACKEND",
    "packages/shared",
    "packages/web",
    "SERVICES/ml-service"
  ],
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "npm run -w packages/web dev",
    "backend": "npm run -w vectraguard-backend start",
    "backend:dev": "npm run -w vectraguard-backend dev",
    "ml-service": "npm run -w vectraguard-ml-service start",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "type-check": "npm run type-check --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present && rm -rf node_modules"
  },
  "dependencies": {
    "@expo/config-plugins": "^55.0.9",
    "@expo/ngrok": "^4.1.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.16.2",
    "@react-navigation/native": "^7.2.5",
    "ansi-escapes": "^7.3.0",
    "expo": "^55.0.25",
    "expo-constants": "~55.0.16",
    "expo-dev-client": "~55.0.35",
    "expo-linear-gradient": "~55.0.14",
    "expo-linking": "~55.0.15",
    "expo-localization": "~55.0.15",
    "expo-modules-core": "~55.0.25",
    "expo-router": "~55.0.16",
    "expo-splash-screen": "^55.0.21",
    "expo-sqlite": "~55.0.16",
    "expo-status-bar": "~55.0.6",
    "expo-system-ui": "^55.0.18",
    "expo-web-browser": "~55.0.16",
    "firebase": "^12.14.0",
    "firebase-admin": "^10.3.0",
    "i18next": "^26.3.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.0",
    "react-i18next": "^17.0.8",
    "react-native": "^0.83.9",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "^0.7.1",
    "sqlite3": "^6.0.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "~19.2.10",
    "expo-modules-autolinking": "~55.0.7",
    "typescript": "~5.9.2"
  }
}
